# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Places API
GOOGLE_PLACES_API_KEY=AIza...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Upstash Redis (rate limiting + budget counter + cache)
UPSTASH_REDIS_REST_URL=https://<db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Nominatim (geocoding) — must include contact email per ToS
NOMINATIM_USER_AGENT=food-discovery/0.1 (you@example.com)

# Budget guard — daily spend ceiling for Google Places API calls
# Each call costs ~$0.02; default $5 = 250 calls/day
PLACES_DAILY_BUDGET_USD=5

# Admin stats endpoint — keep secret, min 8 chars
ADMIN_KEY=change-me-in-production

# Alert webhook (Slack / Discord / generic POST JSON)
# Leave blank to disable budget alerts
ALERT_WEBHOOK_URL=

# Sentry error tracking (server-side DSN — not public)
SENTRY_DSN=

# Sentry error tracking (client-side DSN — safe to expose)
NEXT_PUBLIC_SENTRY_DSN=

# Public app URL — used to generate absolute share links (/s/[shortId])
# Set to your production domain in deployment (e.g. https://fooddiscovery.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
